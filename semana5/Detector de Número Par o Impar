#Detector de Número Par o Impar 
#algoritmo
#leer el numero entero 
#si el numero es divisible entre 2 entoces es par
#si no de lo contrario decir que es un numero impar

numero = int(input("Ingrese un número entero: "))

if numero % 2 == 0:
    print("El número", numero, "es PAR")
else:
    print("El número", numero, "es IMPAR")
